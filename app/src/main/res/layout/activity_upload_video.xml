<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".screens.UploadVideoActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bgColorDarkRed">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/backPressIC"
                style="@style/imageButtonStyle"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:layout_marginStart="5dp"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="0dp"
                android:layout_marginBottom="0dp"
                android:padding="5dp"
                android:paddingStart="0dp"
                android:src="@drawable/back_arrow_ic" />

            <TextView
                android:layout_toEndOf="@id/backPressIC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="New Post"
                android:textColor="@color/textColorWhite"
                android:textSize="18sp" />

            <ImageView
                android:id="@+id/uploadVideoBtn"
                android:layout_width="35dp"
                android:layout_marginEnd="15dp"
                android:layout_height="35dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:src="@drawable/ic_check"
                app:tint="@color/textColorYellow"/>

        </RelativeLayout>

    </androidx.appcompat.widget.Toolbar>


    <RelativeLayout
        android:layout_below="@id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        >

        <RelativeLayout
            android:id="@+id/l1"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            >

            <ImageView
                android:id="@+id/videoThumbnail"
                android:layout_width="130dp"
                android:layout_height="160dp"
                android:layout_gravity="center_horizontal"
                android:layout_margin="5dp"
                android:scaleType="centerCrop"
                android:src="@drawable/item2" />

            <EditText
                android:id="@+id/captionForVideoET"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginStart="5dp"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="5dp"
                android:layout_toEndOf="@id/videoThumbnail"
                android:background="@drawable/white_border"
                android:backgroundTint="@color/black"
                android:gravity="left"
                android:hint="Write @ for tagging friends and  # for hashtag"
                android:inputType="textMultiLine"
                android:maxLines="5"
                android:minLines="3"
                android:padding="10dp"
                android:textColor="@color/textColorBlack"
                android:textColorHint="@color/Gray" />

        </RelativeLayout>


        <RelativeLayout
            android:visibility="gone"
            android:id="@+id/cycleView"
            android:layout_below="@id/l1"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            >

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/userCycle"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:listitem="@layout/userlistrecycledesign"
                android:orientation="vertical"
                />

        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/showBtnView"
            android:layout_below="@id/cycleView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            >


            <TextView
                android:id="@+id/addLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/cardview_look"
                android:backgroundTint="@color/bgColorDarkRed"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:drawableEnd="@drawable/add_ic"
                android:drawableTint="@color/white"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="Add location"
                android:textColor="@color/textColorWhite"
                android:textSize="16sp" />


            <TextView
                android:layout_below="@id/addLocation"
                android:id="@+id/addHashtagBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/cardview_look"
                android:backgroundTint="@color/bgColorDarkRed"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:drawableEnd="@drawable/add_ic"
                android:drawableTint="@color/white"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="# Hashtags"
                android:textColor="@color/textColorWhite"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tagFriendBtn"
                android:layout_below="@id/addHashtagBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/cardview_look"
                android:backgroundTint="@color/bgColorDarkRed"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:drawableEnd="@drawable/add_ic"
                android:drawableTint="@color/white"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="\@ Friends"
                android:textColor="@color/textColorWhite"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/postSettingBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp"
                android:layout_below="@id/tagFriendBtn"
                android:background="@drawable/cardview_look"
                android:backgroundTint="@color/bgColorDarkRed"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:drawableEnd="@drawable/arrow_right"
                android:drawableTint="@color/white"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="Post Setting"
                android:textColor="@color/textColorWhite"
                android:textSize="16sp" />


        </RelativeLayout>

        <androidx.cardview.widget.CardView
            android:visibility="gone"
            android:id="@+id/uploadVideoBtn3333"
            style="@style/carViewStyle"
            android:layout_width="match_parent"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="15dp"
            android:layout_marginTop="15dp"
            android:layout_marginEnd="15dp"
            android:layout_marginBottom="15dp"
            app:cardBackgroundColor="@color/bgColorYellow">

            <TextView
                style="@style/textViewStyle"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="Upload Video"
                android:textAlignment="center"
                android:textColor="@color/textColorWhite"
                android:textStyle="bold" />

        </androidx.cardview.widget.CardView>

    </RelativeLayout>

</RelativeLayout>